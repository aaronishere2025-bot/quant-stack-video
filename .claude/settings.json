{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 /mnt/d/ai-workspace/scripts/kit/hooks/block_git_writes.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "/usr/bin/python3 /mnt/d/ai-workspace/scripts/kit/hooks/block_offlimits_paths.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 /mnt/d/ai-workspace/scripts/kit/hooks/block_secrets.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "/usr/bin/python3 /mnt/d/ai-workspace/scripts/kit/hooks/block_offlimits_paths.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
